        <SQLTask:SqlTaskData
          SQLTask:Connection="{06C4C3A1-F613-4FED-924B-A97AF1B855FC}"
          SQLTask:SqlStatementSource="IF NOT EXISTS (&#xA;SELECT 1 FROM sys.indexes&#xA;WHERE object_id = OBJECT_ID('dbo.stg_geolite')&#xA;AND name = 'IX_stg_geolite_range'&#xA;)&#xA;BEGIN&#xA;CREATE INDEX IX_stg_geolite_range ON dbo.stg_geolite(ip_start_int, ip_end_int) INCLUDE(autonomous_system_number, autonomous_system_organization, network); &#xA;END" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
