      DTS:ThreadHint="2">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{06C4C3A1-F613-4FED-924B-A97AF1B855FC}"
          SQLTask:SqlStatementSource="MERGE dbo.DimASN AS target&#xA;USING (&#xA;    SELECT DISTINCT&#xA;        autonomous_system_number        AS ASNumber,&#xA;        autonomous_system_organization  AS ASOrganization,&#xA;        network                         AS NetworkCIDR,&#xA;        DW_row_checksum_asn AS src_checksum&#xA;    FROM dbo.stg_geolite&#xA;    WHERE network IS NOT NULL&#xA;) AS source&#xA;ON target.NetworkCIDR = source.NetworkCIDR&#xA;WHEN NOT MATCHED THEN&#xA;    INSERT (ASNumber, ASOrganization, NetworkCIDR,&#xA;            DW_row_checksum, DW_run_id, DW_updated_on, DW_source_system)&#xA;    VALUES (source.ASNumber, source.ASOrganization, source.NetworkCIDR,&#xA;            source.src_checksum, ?, GETDATE(), 'GeoLite2 ASN')&#xA;WHEN MATCHED AND target.DW_row_checksum &lt;&gt; source.src_checksum THEN&#xA;    UPDATE SET&#xA;        target.ASNumber         = source.ASNumber,&#xA;        target.ASOrganization   = source.ASOrganization,&#xA;        target.DW_row_checksum  = source.src_checksum,&#xA;        target.DW_run_id        = ?,&#xA;        target.DW_updated_on    = GETDATE(),&#xA;        target.DW_source_system = 'GeoLite2 ASN';" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
          <SQLTask:ParameterBinding
            SQLTask:ParameterName="0"
            SQLTask:DtsVariableName="User::RunId"
            SQLTask:ParameterDirection="Input"
            SQLTask:DataType="129"
            SQLTask:ParameterSize="-1" />
          <SQLTask:ParameterBinding
            SQLTask:ParameterName="1"
            SQLTask:DtsVariableName="User::RunId"
            SQLTask:ParameterDirection="Input"
            SQLTask:DataType="129"
            SQLTask:ParameterSize="-1" />
        </SQLTask:SqlTaskData>
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Merge DimDate"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{66e78f64-3617-48ee-af5b-f128d427c21c}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Merge DimDate"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="4">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{06C4C3A1-F613-4FED-924B-A97AF1B855FC}"
          SQLTask:SqlStatementSource="MERGE dbo.DimDate AS target&#xA;USING (&#xA;    SELECT DISTINCT&#xA;        datetime                        AS FullDate,&#xA;        YEAR(datetime)                  AS [Year],&#xA;        MONTH(datetime)                 AS [Month],&#xA;        DAY(datetime)                   AS [Day],&#xA;        DATEPART(HOUR, datetime)        AS [Hour],&#xA;        DATEPART(MINUTE, datetime)      AS [Minute],&#xA;        DATENAME(WEEKDAY, datetime)     AS [WeekDay],&#xA;        DW_row_checksum_date AS src_checksum&#xA;    FROM dbo.stg_honeypot&#xA;    WHERE datetime IS NOT NULL&#xA;) AS source&#xA;ON target.FullDate = source.FullDate&#xA;WHEN NOT MATCHED THEN&#xA;    INSERT (FullDate, [Year], [Month], [Day], [Hour], [Minute], [WeekDay],&#xA;            DW_row_checksum, DW_run_id, DW_updated_on, DW_source_system)&#xA;    VALUES (source.FullDate, source.[Year], source.[Month], source.[Day],&#xA;            source.[Hour], source.[Minute], source.[WeekDay],&#xA;            source.src_checksum, ?, GETDATE(), 'Honeypot Logs');" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
          <SQLTask:ParameterBinding
            SQLTask:ParameterName="0"
            SQLTask:DtsVariableName="User::RunId"
            SQLTask:ParameterDirection="Input"
            SQLTask:DataType="129"
            SQLTask:ParameterSize="-1" />
        </SQLTask:SqlTaskData>
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Merge DimGeoOrigin"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{e1fece9f-5377-4985-93b3-dc22fc17f16d}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Merge DimGeoOrigin"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="3">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{06C4C3A1-F613-4FED-924B-A97AF1B855FC}"
          SQLTask:SqlStatementSource="MERGE dbo.DimGeoOrigin AS target&#xA;USING (&#xA;    SELECT DISTINCT&#xA;        cc          AS CountryCode,&#xA;        country     AS Country,&#xA;        locale      AS Locale,&#xA;        localeabbr  AS LocaleAbrev,&#xA;        postalcode  AS PostalCode,&#xA;        latitude    AS Latitude,&#xA;        longitude   AS Longitude,&#xA;        DW_row_checksum_geo AS src_checksum&#xA;    FROM dbo.stg_honeypot&#xA;) AS source&#xA;ON  target.CountryCode = source.CountryCode&#xA;AND target.Locale      = source.Locale&#xA;AND target.PostalCode  = source.PostalCode&#xA;AND ISNULL(target.Latitude, 0)  = ISNULL(source.Latitude, 0)&#xA;AND ISNULL(target.Longitude, 0) = ISNULL(source.Longitude, 0)&#xA;WHEN NOT MATCHED THEN&#xA;    INSERT (CountryCode, Country, Locale, LocaleAbrev, PostalCode, Latitude, Longitude,&#xA;            DW_row_checksum, DW_run_id, DW_updated_on, DW_source_system)&#xA;    VALUES (source.CountryCode, source.Country, source.Locale, source.LocaleAbrev,&#xA;            source.PostalCode, source.Latitude, source.Longitude,&#xA;            source.src_checksum, ?, GETDATE(), 'Honeypot Logs')&#xA;WHEN MATCHED AND target.DW_row_checksum &lt;&gt; source.src_checksum THEN&#xA;    UPDATE SET&#xA;        target.Country          = source.Country,&#xA;        target.LocaleAbrev      = source.LocaleAbrev,&#xA;        target.Latitude         = source.Latitude,&#xA;        target.Longitude        = source.Longitude,&#xA;        target.DW_row_checksum  = source.src_checksum,&#xA;        target.DW_run_id        = ?,&#xA;        target.DW_updated_on    = GETDATE(),&#xA;        target.DW_source_system = 'Honeypot Logs';" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
          <SQLTask:ParameterBinding
            SQLTask:ParameterName="0"
            SQLTask:DtsVariableName="User::RunId"
            SQLTask:ParameterDirection="Input"
            SQLTask:DataType="129"
            SQLTask:ParameterSize="-1" />
          <SQLTask:ParameterBinding
            SQLTask:ParameterName="1"
            SQLTask:DtsVariableName="User::RunId"
            SQLTask:ParameterDirection="Input"
            SQLTask:DataType="129"
            SQLTask:ParameterSize="-1" />
        </SQLTask:SqlTaskData>
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Merge DimHost"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{098be736-fe5a-40fe-9d10-381d9ef7b174}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Merge DimHost"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="1">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{06C4C3A1-F613-4FED-924B-A97AF1B855FC}"
          SQLTask:SqlStatementSource="MERGE dbo.DimHost AS target&#xA;USING (&#xA;    SELECT DISTINCT&#xA;        host AS HostName,&#xA;        CASE&#xA;            WHEN CHARINDEX('-', host) &gt; 0&#xA;            THEN SUBSTRING(host, CHARINDEX('-', host) + 1, LEN(host))&#xA;            ELSE NULL&#xA;        END AS Region,&#xA;        DW_row_checksum_host AS src_checksum&#xA;    FROM dbo.stg_honeypot&#xA;    WHERE host IS NOT NULL&#xA;) AS source&#xA;ON target.HostName = source.HostName&#xA;WHEN NOT MATCHED THEN&#xA;    INSERT (HostName, Region, DW_row_checksum, DW_run_id, DW_updated_on, DW_source_system)&#xA;    VALUES (source.HostName, source.Region, source.src_checksum, ?, GETDATE(), 'Honeypot Logs')&#xA;WHEN MATCHED AND target.DW_row_checksum &lt;&gt; source.src_checksum THEN&#xA;    UPDATE SET&#xA;        target.Region           = source.Region,&#xA;        target.DW_row_checksum  = source.src_checksum,&#xA;        target.DW_run_id        = ?,&#xA;        target.DW_updated_on    = GETDATE(),&#xA;        target.DW_source_system = 'Honeypot Logs';" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
          <SQLTask:ParameterBinding
            SQLTask:ParameterName="0"
            SQLTask:DtsVariableName="User::RunId"
            SQLTask:ParameterDirection="Input"
            SQLTask:DataType="129"
            SQLTask:ParameterSize="-1" />
          <SQLTask:ParameterBinding
            SQLTask:ParameterName="1"
            SQLTask:DtsVariableName="User::RunId"
            SQLTask:ParameterDirection="Input"
            SQLTask:DataType="129"
            SQLTask:ParameterSize="-1" />
        </SQLTask:SqlTaskData>
      </DTS:ObjectData>
    </DTS:Executable>
