    <DTS:Executable
      DTS:refId="Package\Calculate IP Ranges"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{76211a4d-fbf3-43e9-9426-c5f5585622ee}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Calculate IP Ranges"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{06C4C3A1-F613-4FED-924B-A97AF1B855FC}"
          SQLTask:SqlStatementSource="UPDATE dbo.stg_geolite&#xA;SET&#xA;ip_start_int = dbo.fn_IPtoInt(&#xA;LEFT(network, CHARINDEX('/', network) - 1)&#xA;),&#xA;ip_end_int = dbo.fn_IPtoInt(&#xA;LEFT(network, CHARINDEX('/', network) - 1)&#xA;)&#xA;+ CAST(&#xA;POWER(2.0, 32 - CAST(RIGHT(network, LEN(network) - CHARINDEX('/',&#xA;network)) AS INT)) - 1&#xA;AS BIGINT)&#xA;WHERE network IS NOT NULL&#xA;AND CHARINDEX('/', network) &gt; 0;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
